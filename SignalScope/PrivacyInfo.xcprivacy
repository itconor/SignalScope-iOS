<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- SignalScope does not track users across apps or websites -->
	<key>NSPrivacyTracking</key>
	<false/>

	<!-- No tracking domains -->
	<key>NSPrivacyTrackingDomains</key>
	<array/>

	<!-- Data collected: none sent to developer servers.
	     All data stays on the user's own hub (user-configured URL). -->
	<key>NSPrivacyCollectedDataTypes</key>
	<array/>

	<!-- Required reason APIs used by this app -->
	<key>NSPrivacyAccessedAPITypes</key>
	<array>
		<dict>
			<!-- UserDefaults / @AppStorage — used to store hub URL, API token,
			     refresh interval, acknowledged faults, and recent fault history.
			     All data stays local on the device. -->
			<key>NSPrivacyAccessedAPIType</key>
			<string>NSPrivacyAccessedAPICategoryUserDefaults</string>
			<key>NSPrivacyAccessedAPITypeReasons</key>
			<array>
				<!-- CA92.1: Accessed from the same app -->
				<string>CA92.1</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
